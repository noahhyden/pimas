{
  "name": "@pimas/dom",
  "version": "0.0.0",
  "description": "Pimas DOM renderer + JSX runtime. Turns the reactive core into real DOM nodes. (Phase 2 — in progress.)",
  "type": "module",
  "license": "MIT",
  "author": "Noah Hyden",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": ["dist", "src"],
  "peerDependencies": {
    "@pimas/reactive": "*"
  },
  "devDependencies": {
    "@pimas/reactive": "*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": ["jsx", "dom", "renderer", "reactive"]
}

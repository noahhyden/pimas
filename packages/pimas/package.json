{
  "name": "pimas",
  "version": "0.0.0",
  "description": "Pimas — one-install facade re-exporting the reactive core and DOM renderer. Power users can import @pimas/* directly.",
  "type": "module",
  "license": "MIT",
  "author": "Noah Hyden",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "dependencies": {
    "@pimas/reactive": "*",
    "@pimas/dom": "*"
  },
  "keywords": ["reactive", "signals", "ui", "framework"]
}

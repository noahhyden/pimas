{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // Wired ahead for Phase 2 (JSX → DOM). No .tsx files exist yet, so these
    // are inert until we add the jsx-runtime. When we do, authoring is:
    //   /** @jsxImportSource pimas */  — or set per-file / project-wide here.
    "jsx": "react-jsx",
    "jsxImportSource": "pimas"
  },
  "include": ["src", "test"]
}

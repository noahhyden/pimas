{
  "//": "Typecheck config. Maps the public subpaths to source so .tsx files resolve the JSX runtime and `pimas`/`pimas/dom` imports without a build.",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "pimas": ["./src/reactive/index.ts"],
      "pimas/dom": ["./src/dom/index.ts"],
      "pimas/server": ["./src/server/index.ts"],
      "pimas/resume": ["./src/dom/resume.ts"],
      "pimas/hydrate": ["./src/dom/claim.ts"],
      "pimas/flow": ["./src/flow/index.ts"],
      "pimas/store": ["./src/store/index.ts"],
      "pimas/jsx-runtime": ["./src/dom/jsx-runtime.ts"],
      "pimas/jsx-dev-runtime": ["./src/dom/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src", "test"]
}
